task.spawn(function()
    while true do
        pcall(function()
            local char = LocalPlayer.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")

            if char and char:FindFirstChild("Humanoid") then
                char.Humanoid.WalkSpeed = getgenv().WS
            end

            if getgenv().AutoTicket and hrp then
                local tk = workspace:FindFirstChild("Game")
                if tk and tk:FindFirstChild("Effects") and tk.Effects:FindFirstChild("Tickets") then
                    for _,t in ipairs(tk.Effects.Tickets:GetChildren()) do
                        local p = t:IsA("BasePart") and t or t.PrimaryPart
                        if p then
                            hrp.CFrame = p.CFrame + Vector3.new(0,5,0)
                            break
                        end
                    end
                end
            end

            if getgenv().AutoRevive and char and char:GetAttribute("Downed") then
                ReplicatedStorage.Events.Player.ChangePlayerMode:FireServer(true)
            end
        end)
        task.wait(0.05)
    end
end)

RunService.Heartbeat:Connect(function()
    if getgenv().PlayerESP then
        for _,p in ipairs(Players:GetPlayers()) do
            if p~=LocalPlayer and p.Character then
                createNametag(p.Character,p.Name,Color3.fromRGB(200,220,255))
            end
        end
    end

    if getgenv().NextbotESP then
        for _,o in ipairs(workspace:GetDescendants()) do
            if o:IsA("Model") and isNextbot(o) then
                createNametag(o,o.Name,Color3.fromRGB(255,80,80))
            end
        end
    end
end)

