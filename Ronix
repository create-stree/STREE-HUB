local nametagCache = {}

local nextbotNames = {}
if ReplicatedStorage:FindFirstChild("NPCs") then
    for _, npc in ipairs(ReplicatedStorage.NPCs:GetChildren()) do
        table.insert(nextbotNames, npc.Name)
    end
end

local nextbotKeywords = {"nextbot","scp","monster","zombie","ghost","demon"}

local function isNextbot(model)
    if not model or not model:IsA("Model") then return false end
    if Players:GetPlayerFromCharacter(model) then return false end
    if table.find(nextbotNames, model.Name) then return true end
    local n = model.Name:lower()
    for _,v in ipairs(nextbotKeywords) do
        if n:find(v) then return true end
    end
    if model:FindFirstChild("HumanoidRootPart") and not model:FindFirstChild("Humanoid") then
        return true
    end
    return false
end

local function destroyNametag(t)
    if nametagCache[t] then
        pcall(function() nametagCache[t]:Destroy() end)
        nametagCache[t] = nil
    end
end

local function clearAllNametags()
    for t,_ in pairs(nametagCache) do
        destroyNametag(t)
    end
    nametagCache = {}
end

local function removeTracer(tbl,k)
    local t = tbl[k]
    if t then
        t.Visible = false
        pcall(function() t:Remove() end)
    end
    tbl[k] = nil
end

local function clearTracers(tbl)
    for k,_ in pairs(tbl) do
        removeTracer(tbl,k)
    end
end

local function createNametag(target,text,color)
    if not target.Parent then return end
    local root = target:FindFirstChild("HumanoidRootPart") or target.PrimaryPart
    if not root then return end
    destroyNametag(target)
    local g = Instance.new("BillboardGui")
    g.Name = "VexNametag"
    g.Adornee = root
    g.Size = UDim2.new(0,120,0,30)
    g.StudsOffset = Vector3.new(0,3,0)
    g.AlwaysOnTop = true
    g.Parent = root
    local l = Instance.new("TextLabel")
    l.Size = UDim2.new(1,0,1,0)
    l.BackgroundTransparency = 1
    l.Text = text
    l.TextColor3 = color
    l.TextScaled = true
    l.Font = Enum.Font.GothamBold
    l.Parent = g
    nametagCache[target] = g
end

local function createTracer()
    local t = Drawing.new("Line")
    t.Visible = false
    t.Thickness = 1.5
    t.Transparency = 1
    return t
end

RunService.RenderStepped:Connect(function()
    local cam = workspace.CurrentCamera
    if not cam then return end
    local bottom = Vector2.new(cam.ViewportSize.X/2,cam.ViewportSize.Y)

    if getgenv().PlayerTracers then
        for _,p in ipairs(Players:GetPlayers()) do
            if p~=LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                if not playerTracerElements[p] then
                    playerTracerElements[p] = createTracer()
                end
                local tr = playerTracerElements[p]
                local pos,vis = cam:WorldToViewportPoint(p.Character.HumanoidRootPart.Position)
                tr.Visible = vis
                if vis then
                    tr.From = bottom
                    tr.To = Vector2.new(pos.X,pos.Y)
                    tr.Color = Color3.fromRGB(200,220,255)
                end
            end
        end
    end

    if getgenv().NextbotTracers then
        for _,obj in ipairs(workspace:GetDescendants()) do
            if obj:IsA("Model") and isNextbot(obj) then
                local hrp = obj:FindFirstChild("HumanoidRootPart") or obj.PrimaryPart
                if hrp then
                    if not botTracerElements[obj] then
                        botTracerElements[obj] = createTracer()
                    end
                    local tr = botTracerElements[obj]
                    local pos,vis = cam:WorldToViewportPoint(hrp.Position)
                    tr.Visible = vis
                    if vis then
                        tr.From = bottom
                        tr.To = Vector2.new(pos.X,pos.Y)
                        tr.Color = Color3.fromRGB(255,70,70)
                    end
                end
            end
        end
    end
end)

