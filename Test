--@key_validation via LuaEgis SDK
local function validateKey(userKey: string): boolean
    local api = loadstring(game:HttpGet("https://sdk.luaegis.net/sdk/library.lua"))()
    api.script_id = SCRIPT_ID

    local status = api.check_key(userKey)

    if status.code == "KEY_VALID" then
        local expiry = status.data.auth_expire == 0
            and "Permanent"
            or math.floor((status.data.auth_expire - os.time()) / 3600) .. "h remaining"

        notify("STREE HUB", "Key valid! Plan: " .. (status.data.note or "Free") .. " | " .. expiry, 4)
        return true

    elseif status.code == "KEY_HWID_LOCKED" then
        notify("STREE HUB", "Key terikat ke device lain. Reset HWID via Discord.", 5)

    elseif status.code == "KEY_EXPIRED" then
        notify("STREE HUB", "Key sudah expired. Beli atau renew key baru.", 5)

    elseif status.code == "KEY_BANNED" then
        notify("STREE HUB", "Key di-ban: " .. status.message, 5)

    elseif status.code == "KEY_INCORRECT" then
        notify("STREE HUB", "Key salah atau tidak valid.", 4)

    else
        notify("STREE HUB", "Gagal menghubungi server. Coba lagi.", 4)
    end

    return false
end

--@main_loader
local function loadGame(gameData: loader_config)
    local success, err = pcall(function()
        local content = game:HttpGet(gameData.free)
        local fn = loadstring(content)
        if not fn then error("Gagal compile script") end
        fn()
    end)

    if not success then
        warn("[STREE HUB] Loader error:", err)
        notify("STREE HUB", "Gagal load script: " .. tostring(err), 5)
    end
end

--@entry_point
local function main()
    local gameId   = game.GameId
    local gameData = gameScripts[gameId] or gameScripts[game.PlaceId]
    local gameName = gameData and gameData.name or "Unknown Game"

    -- 1. Splash screen
    showSplash()

    -- 2. Detect game
    notify("STREE HUB", "Game terdeteksi: " .. gameName, 3)
    task.wait(2)

    -- 3. Game tidak didukung
    if not gameData then
        notify("STREE HUB", "Game ini belum didukung.", 5)
        task.wait(1)
        PLAYER:Kick("[STREE HUB] Game tidak didukung.")
        return
    end

    -- 4. Key input loop (max 3 percobaan)
    local attempts = 0
    local maxAttempts = 3

    while attempts < maxAttempts do
        attempts += 1
        notify("STREE HUB", "Masukkan key kamu. Percobaan " .. attempts .. "/" .. maxAttempts, 3)
        task.wait(1.5)

        local userKey = promptKeyInput()
        local valid   = validateKey(userKey)

        if valid then
            -- 5. Load game script
            task.wait(1)
            notify("STREE HUB", "Memuat " .. gameName .. "...", 3)
            task.wait(1.5)
            loadGame(gameData)
            return
        end

        if attempts < maxAttempts then
            task.wait(2)
        end
    end

    -- max attempts exceeded
    notify("STREE HUB", "Key gagal " .. maxAttempts .. "x. Keluar.", 4)
    task.wait(2)
    PLAYER:Kick("[STREE HUB] Terlalu banyak percobaan key gagal.")
end

main()
