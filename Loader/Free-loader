local function validateKey(userKey)
    local httpRequest = (syn and syn.request) or (http and http.request) or http_request or (Fluxus and Fluxus.request) or request
    local function apiGet(endpoint)
        local url = "https://api.luaegis.net" .. endpoint
        print("[DEBUG] API URL: " .. url)
        local success, response = pcall(function()
            local headers = {
                ["Authorization"] = "Bearer " .. LUAEGIS_API_KEY,
                ["x-api-key"] = LUAEGIS_API_KEY,
                ["Content-Type"] = "application/json",
            }
            if httpRequest then
                return httpRequest({
                    Method = "GET",
                    Url = url,
                    Headers = headers,
                })
            else
                return HttpService:RequestAsync({
                    Method = "GET",
                    Url = url,
                    Headers = headers,
                })
            end
        end)
        print("[DEBUG] Success: " .. tostring(success))
        if success and response then
            print("[DEBUG] Status Code: " .. tostring(response.StatusCode))
            print("[DEBUG] Body: " .. tostring(response.Body))
            local isSuccess = response.Success or (response.StatusCode and response.StatusCode >= 200 and response.StatusCode < 300)
            if isSuccess and response.Body then
                local ok, decoded = pcall(function()
                    return HttpService:JSONDecode(response.Body)
                end)
                if ok then
                    return decoded
                else
                    print("[DEBUG] JSON Decode failed: " .. tostring(decoded))
                end
            end
        end
        print("[DEBUG] HTTP request failed")
        return nil
    end

    local function getLocalHwid()
        local success, result = pcall(function()
            return cloneref(game:GetService("RbxAnalyticsService")):GetClientId()
        end)
        return success and result or ""
    end

    local data = apiGet(string.format("/api/v3/projects/%s/users/%s", LUAEGIS_PROJECT_ID, userKey))
    print("[DEBUG] Full response data: " .. tostring(data))

    if not data then
        ShowStatus("Failed to connect to server.", true, false)
        return false
    end

    if not data.success then
        local errMsg = data.message or "Unknown error"
        print("[DEBUG] API Error: " .. errMsg)
        ShowStatus("Server error: " .. errMsg, true, false)
        return false
    end

    print("[DEBUG] User data status: " .. tostring(data.data.user_data.status))
    local userData = data.data.user_data

    if userData.status == "banned" then
        local reason = userData.ban_reason or "Unknown"
        local untilStr = userData.ban_until and os.date("%Y-%m-%d", userData.ban_until) or "Permanent"
        ShowStatus("Key is banned: " .. reason .. " until " .. untilStr, true, false)
        return false
    end

    local localHwid = getLocalHwid()
    local storedHwid = userData.hwid or userData.fingerprint or ""
    if storedHwid == "null" then storedHwid = "" end

    if storedHwid ~= "" and storedHwid ~= localHwid then
        ShowStatus("Key is bound to another device. Please reset your HWID.", true, false)
        return false
    end

    local expiry = userData.key_expire
    local expiryStr
    if not expiry or expiry == 0 then
        expiryStr = "Permanent"
    else
        local remaining = expiry - os.time()
        if remaining <= 0 then
            ShowStatus("Key has expired.", true, false)
            return false
        end
        local hours = math.floor(remaining / 3600)
        local days = math.floor(remaining / 86400)
        expiryStr = days > 0 and (days .. "d " .. (hours % 24) .. "h remaining") or (hours .. "h remaining")
    end

    local note = userData.key_note or "Free"
    ShowStatus("Key valid! " .. expiryStr, false, true)
    notify("STREE HUB", "Key valid â€” " .. note .. " | " .. expiryStr, 4)
    return true
end

