local function UpdateParticles()
    if State.IsDestroyed or not UI.ParticleContainer then return end
    local screenSize   = UI.ScreenGui.AbsoluteSize
    local mouseScreenX = State.MousePosition.X / screenSize.X
    local mouseScreenY = State.MousePosition.Y / screenSize.Y

    for i = #State.Particles, 1, -1 do
        local p = State.Particles[i]
        if not p or not p.frame or not p.frame.Parent then
            table.remove(State.Particles, i)
            continue
        end
        local pos = p.frame.Position
        local age = tick() - p.created
        if pos.Y.Scale < -0.3 or age > p.lifetime then
            p.frame:Destroy()
            table.remove(State.Particles, i)
            continue
        end
        local dx    = pos.X.Scale - mouseScreenX
        local dy    = pos.Y.Scale - mouseScreenY
        local dist  = math.sqrt(dx * dx + dy * dy)
        local rfx, rfy = 0, 0
        if dist < 0.15 and dist > 0 then
            local pow = ((0.15 - dist) / 0.15) * 0.08 / p.mass
            rfx = (dx / dist) * pow
            rfy = (dy / dist) * pow
        end
        p.repelForce.x = p.repelForce.x * 0.85 + rfx * 0.15
        p.repelForce.y = p.repelForce.y * 0.85 + rfy * 0.15

        local nx = pos.X.Scale + p.vx + p.repelForce.x
        local ny = pos.Y.Scale + p.vy + p.repelForce.y
        if nx <= -0.2 then nx = 1.2 elseif nx >= 1.2 then nx = -0.2 end
        local t = tick()
        nx = nx + math.sin(t * 1.5 + p.wobblePhase) * 0.002
        ny = ny + math.cos(t * 1.05 + p.wobblePhase) * 0.001
        p.rotation = p.rotation + p.rotationSpeed
        p.frame.Rotation = p.rotation

        local breathe = math.sin(t * 2.5 + p.pulsePhase) * 0.1 + 1
        local s = p.originalSize * breathe
        p.frame.Size = UDim2.new(0, s, 0, s)
        local tAlpha = math.sin(t * 3 + p.pulsePhase) * 0.1
        p.frame.BackgroundTransparency = math.clamp(p.originalTransparency + tAlpha, 0.5, 0.95)
        p.glow.BackgroundTransparency  = dist < 0.2 and (0.7 + dist / 0.2 * 0.2) or 0.9
        p.highlight.BackgroundTransparency = math.sin(t * 4 + p.pulsePhase) * 0.2 + 0.3
        p.vx = p.vx * 0.995
        p.vy = p.vy * 0.998
        p.frame.Position = UDim2.new(nx, 0, ny, 0)
    end
end

