        local t = textInput.Text
        if #t > Config.MaxKeyLength then
            textInput.Text = t:sub(1, Config.MaxKeyLength)
            ShowStatus("Maximum " .. Config.MaxKeyLength .. " characters.", true, false)
        end
        UpdateCharCounter()
        ClearStatus()
    end)

    local inputGlowTw = nil
    textInput.Focused:Connect(function()
        inputGlowFrame.Visible = true
        TweenService:Create(inputStroke, TweenInfo.new(0.2, Enum.EasingStyle.Quad), { Color = Colors.NeonGreen, Transparency = 0.1 }):Play()
        TweenService:Create(inputGlowStroke, TweenInfo.new(0.2, Enum.EasingStyle.Quad), { Transparency = 0.1 }):Play()
        if inputGlowTw then inputGlowTw:Cancel() end
        inputGlowTw = TweenService:Create(inputGlowGrad, TweenInfo.new(2, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut, -1), { Rotation = 360 })
        inputGlowTw:Play()
        ClearStatus()
    end)
    textInput.FocusLost:Connect(function()
        TweenService:Create(inputStroke, TweenInfo.new(0.2, Enum.EasingStyle.Quad), { Color = Colors.Border, Transparency = 0.3 }):Play()
        TweenService:Create(inputGlowStroke, TweenInfo.new(0.3, Enum.EasingStyle.Quad), { Transparency = 0.8 }):Play()
        if inputGlowTw then inputGlowTw:Cancel() inputGlowGrad.Rotation = 0 end
        task.delay(0.3, function()
            if inputGlowFrame and inputGlowFrame.Parent then inputGlowFrame.Visible = false end
        end)
    end)

    UIS.InputBegan:Connect(function(input, processed)
        if processed or State.IsDestroyed or State.IsLoading then return end
        if input.KeyCode == Enum.KeyCode.Return and textInput:IsFocused() then
            submitBtn:Activate()
        end
    end)

    submitBtn.MouseButton1Click:Connect(function()
        if State.IsLoading then return end
        local key = textInput.Text
        if key == "" then
            ShowStatus("Please enter an access key.", true, false)
            textInput:CaptureFocus()
            return
        end
        SetLoading(true)
        ShowStatus("Validating key...", false, false)
        task.spawn(function()
            local valid = validateKey(key)
            SetLoading(false)
            if valid then
                task.wait(1)
                ShowStatus("Loading " .. gameData.name .. "...", false, true)
                task.wait(1)
                State.IsDestroyed = true
                sg:Destroy()
                loadGame(gameData)
            end
        end)
    end)

    getKeyBtn.MouseButton1Click:Connect(function()
        pcall(function()
            if setclipboard then
                setclipboard(GET_KEY_URL)
                ShowStatus("Link copied to clipboard!", false, true)
            else
                ShowStatus("Link: " .. GET_KEY_URL, false, false)
            end
        end)
    end)

    task.spawn(function()
        for i = 1, 25 do
            if State.IsDestroyed then break end
            CreateParticle()
            task.wait(math.random(20, 100) / 1000)
        end
        while not State.IsDestroyed and sg and sg.Parent do
            if #State.Particles < Config.ParticleCount then CreateParticle() end
            task.wait(math.random(400, 1200) / 1000)
        end
    end)

    task.spawn(function()
        while not State.IsDestroyed and sg and sg.Parent do
            pcall(UpdateParticles)
            task.wait(1 / Config.ParticleSpeed)
        end
    end)

    task.spawn(function()
        while not State.IsDestroyed and animBorder and animBorder.Parent do
            if State.Animations.BorderTween then State.Animations.BorderTween:Cancel() end
            local tw = TweenService:Create(animGrad,
                TweenInfo.new(4, Enum.EasingStyle.Linear),
                { Rotation = animGrad.Rotation + 360 })
            State.Animations.BorderTween = tw
            tw:Play()
            pcall(function() tw.Completed:Wait() end)
            task.wait(0.05)
        end
    end)

    task.spawn(function()
        while not State.IsDestroyed and iconGlowGrad and iconGlowGrad.Parent do
            if State.Animations.IconTween then State.Animations.IconTween:Cancel() end
            local tw = TweenService:Create(iconGlowGrad,
                TweenInfo.new(3, Enum.EasingStyle.Linear),
                { Rotation = iconGlowGrad.Rotation + 360 })
            State.Animations.IconTween = tw
            tw:Play()
            pcall(function() tw.Completed:Wait() end)
            task.wait(0.05)
        end
    end)

