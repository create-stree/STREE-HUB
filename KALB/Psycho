                                        hrp.CFrame = slot.CFrame + Vector3.new(0,3,0)

                                    elseif slot:IsA("Model") then
                                        hrp.CFrame = slot:GetPivot() + Vector3.new(0,3,0)
                                    end

                                    task.wait(0.35)

                                    collectEvent:FireServer(slotNumber)

                                    task.wait(Delay)
                                end
                            end
