task.spawn(function()
    while true do
        local model = findBrainrot()
        if model then
            SnipeInfo:SetDesc(
                "Rarity : " .. detectRarity(model) ..
                "\nBrainrot : " .. model.Name ..
                "\nMutation : " .. detectMutation(model)
            )
        else
            SnipeInfo:SetDesc("Waiting...")
        end
        task.wait(UPDATE_DELAY)
    end
end)

