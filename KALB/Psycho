Tabs.Main:Toggle({
    Title = "Auto Farm",
    Default = false,
    Callback = function(state)
        autofarm = state

        if not state then
            stopTween()
            setInstantMode(false)
            if farmThread then
                task.cancel(farmThread)
                farmThread = nil
            end
            return
        end

        if farmThread then
            task.cancel(farmThread)
            farmThread = nil
        end

        farmThread = task.spawn(function()
            local kickEvent = ReplicatedStorage.Shared.Packages.Network.rev_KickEvent

            while autofarm do
                if kickMode == "Super Instant" then
                    setInstantMode(true)
                    local _, hrp = getCharacter()
                    if hrp then
                        hrp.CFrame = KICK_POS
                        task.wait(0.2)
                        kickEvent:FireServer(1)
                        task.wait(2)
