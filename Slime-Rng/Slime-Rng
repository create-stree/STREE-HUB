local function getUpgradeTiles()
    local playerGui = localPlayer:FindFirstChild("PlayerGui")
    if not playerGui then return nil end
    local root = playerGui:FindFirstChild("Root")
    if not root then return nil end
    local upgradeScreen = root:FindFirstChild("UpgradeScreen")
    if not upgradeScreen then return nil end
    local upgradeContent = upgradeScreen:FindFirstChild("UpgradeContent")
    if not upgradeContent then return nil end
    local frame = upgradeContent:FindFirstChild("Frame")
    if not frame then return nil end
    return frame:GetChildren()
end

local RS = game:GetService("ReplicatedStorage")
local function getRemote(service)
    return RS:WaitForChild("Packages"):WaitForChild("_Index"):WaitForChild("leifstout_networker@0.3.1"):WaitForChild("networker"):WaitForChild("_remotes"):WaitForChild(service):WaitForChild("RemoteFunction")
end

function Upgrade()
    local upgradeTiles = getUpgradeTiles()
    if upgradeTiles then
        for _, tile in pairs(upgradeTiles) do
            if tile.Name ~= "UIAspectRatioConstraint" and tile.Name ~= "UpgradeHoverInfo" then
                local upgrade = tile.Name:match("^(%S+)Tile")
                if upgrade then
                    getRemote("UpgradeService"):InvokeServer("requestUnlock", upgrade)
                end
            end
        end
    end
end

function Roll()
    getRemote("RollService"):InvokeServer("requestRoll")
end

function ConsumePotions()
    local boosts = {"luck", "ultraLuck", "currency", "rollSpeed"}
    for _, boost in ipairs(boosts) do
        getRemote("BoostService"):InvokeServer("requestUseBoost", boost)
    end
end

function ClaimIndex()
    local rewards = {"basic", "big", "huge", "shiny", "inverted"}
    for _, reward in ipairs(rewards) do
        getRemote("IndexService"):InvokeServer("requestClaimReward", reward)
        task.wait(0.1)
    end
end

function Teleport(worldNum)
    getRemote("ZonesService"):InvokeServer("requestTeleportZone", worldNum)
end

function TeleportBestZone()
    local zones = workspace.Zones:GetChildren()
    local counter = 0
    for _, zone in pairs(zones) do
        local blockerName = "ClientGateBlocker_" .. zone.Name
        local gate = zone:FindFirstChild("Gate") and zone.Gate:FindFirstChild(blockerName)
        if gate and gate.CanCollide ~= true then
            local num = tonumber(zone.Name)
            if num and num > counter then
                counter = num
            end
        end
    end
    Teleport(counter + 1)
end


